
# Normalize text files in the repository
* text=auto

# Unix scripts
*.sh text eol=lf
*.py text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# C++ source
*.c text eol=lf
*.cpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.hh text eol=lf
*.hxx text eol=lf
*.cppm text eol=lf
*.ixx text eol=lf

# Build files
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Configuration and documentation
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf

# Repository files
.gitignore text eol=lf
.gitattributes text eol=lf
.clang-format text eol=lf
