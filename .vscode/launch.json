{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "GDB (CMake Target)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Add libstdc++ printer path",
                    "text": "python import sys; sys.path.insert(0, '${workspaceFolder}/.pixi/envs/default/share/gcc-15.2.0/python')"
                },
                {
                    "description": "Register libstdc++ printers",
                    "text": "python from libstdcxx.v6 import register_libstdcxx_printers; register_libstdcxx_printers(None)"
                }
            ]
        }
    ]
}